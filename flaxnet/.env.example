# apps/api
DATABASE_URL=postgresql://user:pass@localhost:5432/flaxnet
# Phase 1 leads API — existing Workspace.id (create one row first or after migrate)
DEV_WORKSPACE_ID=
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
CLERK_SECRET_KEY=
# Optional: active org when JWT has no org_id (local dev)
CLERK_DEV_ORG_ID=
# Clerk user id (`sub`) of platform owner — full admin API + usage bypass when impersonating
OWNER_USER_ID=
# Optional append-only JSON log file for ops
FLAXNET_LOG_FILE=
# Impersonation session length (ms); client should refresh before expiry
IMPERSONATION_TTL_MS=
CLERK_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# apps/web (Vite)
VITE_API_URL=http://localhost:4000
VITE_CLERK_PUBLISHABLE_KEY=
