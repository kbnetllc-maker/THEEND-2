SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Browser (login + RLS client reads). Never use service role in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Trigger.dev: set TRIGGER_SECRET_KEY to enqueue cloud/dev worker; omit to use in-process setImmediate fallback.
TRIGGER_SECRET_KEY=
# trigger.config.ts project ref (dashboard) — can override via env in CI
TRIGGER_PROJECT_REF=

ANTHROPIC_API_KEY=
# Vision-capable model for /debug (default: claude-3-5-haiku-20241022)
CLAUDE_DEBUG_MODEL=
# Max HTML chars sent to Claude in light/deep fetch probe
DEBUG_MAX_HTML_CHARS=24000
OPENAI_API_KEY=
AI_PROVIDER=claude

NODE_ENV=development
PORT=3000
BATCH_CONCURRENCY=5

CLEARBIT_API_KEY=
PDL_API_KEY=
